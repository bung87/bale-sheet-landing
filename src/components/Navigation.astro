---
const navItems = [
  { label: 'Features', href: '#features' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Support', href: '/support' },
  { label: 'Privacy', href: '/privacy' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-[#fafafa]/80 backdrop-blur-md border-b border-[#e5e5e5]">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-[#1a1a1a] font-semibold text-lg hover:opacity-70 transition-macos">
      <img src="/logo.png" alt="Bale Sheet" width="28" height="28" class="rounded" />
      <span>Bale Sheet</span>
    </a>
    
    <div class="flex items-center gap-6">
      {navItems.map(item => (
        <a 
          href={item.href}
          class="text-sm text-[#6b6b6b] hover:text-[#1a1a1a] transition-macos"
        >
          {item.label}
        </a>
      ))}
      <a
        href="https://apps.apple.com/us/app/bale-sheet/id6727007603"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm px-4 py-2 bg-[#1a1a1a] text-white rounded-lg hover:bg-[#333] transition-macos"
      >
        Get
      </a>
    </div>
  </div>
</nav>
