---
import { Sparkles } from 'lucide-react';
---

<section class="relative min-h-screen flex items-center justify-center pt-14 overflow-hidden">
  <!-- Subtle background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-[#f5f5f5] to-[#fafafa] opacity-50"></div>
  
  <!-- Decorative grid pattern -->
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle, #1a1a1a 1px, transparent 1px); background-size: 24px 24px;"></div>
  
  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-8 bg-white border border-[#e5e5e5] rounded-full text-xs text-[#6b6b6b]">
      <Sparkles size={12} />
      <span>Now available for macOS</span>
    </div>
    
    <!-- Main Title -->
    <h1 class="text-5xl md:text-6xl lg:text-7xl font-semibold text-[#1a1a1a] tracking-tight leading-[1.1] mb-6">
      The Lightweight,<br />
      <span class="text-[#6b6b6b]">Native Spreadsheet</span><br />
      Viewer for macOS
    </h1>
    
    <!-- Subtitle -->
    <p class="text-lg md:text-xl text-[#6b6b6b] max-w-2xl mx-auto mb-10 leading-relaxed">
      Quickly view and export any spreadsheet to Excel format with lightning-fast native performance. 
      No bloat, no cloud, just instant access to your data.
    </p>
    
    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a 
        href="https://apps.apple.com/us/app/bale-sheet/id6727007603"
        target="_blank"
        rel="noopener noreferrer"
        id="download"
        class="group flex items-center gap-2 px-8 py-4 bg-[#1a1a1a] text-white rounded-xl font-medium hover:bg-[#333] transition-macos shadow-lg shadow-black/5"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
        </svg>
        <span>View on App Store</span>
      </a>
      <a 
        href="#features"
        class="px-8 py-4 bg-white border border-[#e5e5e5] text-[#1a1a1a] rounded-xl font-medium hover:border-[#d4d4d4] hover:bg-[#f5f5f5] transition-macos"
      >
        Learn More
      </a>
    </div>
    
    <!-- App preview placeholder -->
    <div class="mt-16 relative">
      <div class="relative mx-auto max-w-4xl">
        <!-- Window chrome -->
        <div class="bg-white rounded-xl shadow-2xl shadow-black/10 border border-[#e5e5e5] overflow-hidden">
          <!-- Title bar -->
          <div class="h-9 bg-[#f5f5f5] border-b border-[#e5e5e5] flex items-center px-4 gap-2">
            <div class="flex gap-2">
              <div class="w-3 h-3 rounded-full bg-[#ff5f57] border border-[#e0443e]"></div>
              <div class="w-3 h-3 rounded-full bg-[#febc2e] border border-[#d89e24]"></div>
              <div class="w-3 h-3 rounded-full bg-[#28c840] border border-[#1aab29]"></div>
            </div>
            <div class="flex-1 text-center text-xs text-[#6b6b6b]">Bale Sheet - Sales Data.xlsx</div>
          </div>
          <!-- Content area -->
          <div class="p-6 bg-white">
            <!-- Spreadsheet mockup -->
            <div class="border border-[#e5e5e5] rounded-lg overflow-hidden">
              <!-- Toolbar -->
              <div class="h-10 bg-[#f5f5f5] border-b border-[#e5e5e5] flex items-center px-3 gap-2">
                <div class="w-6 h-6 rounded bg-white border border-[#e5e5e5]"></div>
                <div class="w-6 h-6 rounded bg-white border border-[#e5e5e5]"></div>
                <div class="w-px h-4 bg-[#e5e5e5]"></div>
                <div class="w-20 h-5 rounded bg-white border border-[#e5e5e5]"></div>
              </div>
              <!-- Grid -->
              <div class="grid grid-cols-6 text-sm">
                <!-- Header row -->
                <div class="h-8 bg-[#f5f5f5] border-r border-b border-[#e5e5e5] flex items-center justify-center text-[#6b6b6b] text-xs font-medium"></div>
                {['A', 'B', 'C', 'D', 'E'].map(col => (
                  <div class="h-8 bg-[#f5f5f5] border-r border-b border-[#e5e5e5] flex items-center justify-center text-[#6b6b6b] text-xs font-medium">{col}</div>
                ))}
                <!-- Data rows -->
                {[
                  ['1', 'Product', 'Q1', 'Q2', 'Q3', 'Q4'],
                  ['2', 'Widget A', '$12K', '$15K', '$18K', '$22K'],
                  ['3', 'Widget B', '$8K', '$11K', '$14K', '$16K'],
                  ['4', 'Widget C', '$5K', '$7K', '$9K', '$12K'],
                ].map((row, i) => (
                  <>
                    <div class="h-10 bg-[#f5f5f5] border-r border-b border-[#e5e5e5] flex items-center justify-center text-[#6b6b6b] text-xs">{row[0]}</div>
                    {row.slice(1).map((cell, j) => (
                      <div class={`h-10 border-r border-b border-[#e5e5e5] flex items-center px-3 ${i === 0 ? 'font-medium text-[#1a1a1a]' : 'text-[#6b6b6b]'}`}>
                        {cell}
                      </div>
                    ))}
                  </>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
