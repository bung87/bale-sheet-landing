---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { label: 'Discord', href: 'https://discord.gg/balesheet', external: true },
  { label: 'Privacy Policy', href: '/privacy', external: false },
  { label: 'Support', href: '/support', external: false },
];
---

<footer class="border-t border-[#e5e5e5] bg-[#fafafa]">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo and copyright -->
      <div class="flex items-center gap-2">
        <img src="/logo.png" alt="Bale Sheet" width="20" height="20" class="rounded opacity-60" />
        <span class="text-sm text-[#6b6b6b]">© {currentYear} Bale Sheet. All rights reserved.</span>
      </div>
      
      <!-- Links -->
      <div class="flex items-center gap-6">
        {footerLinks.map(link => (
          <a 
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class="text-sm text-[#6b6b6b] hover:text-[#1a1a1a] transition-macos"
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
