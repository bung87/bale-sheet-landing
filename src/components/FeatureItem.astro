---
interface Props {
  title: string;
  description: string;
  icon: string;
  reversed?: boolean;
  index: number;
}

const { title, description, icon, reversed = false, index } = Astro.props;
---

<div 
  class={`feature-item flex flex-col ${reversed ? 'lg:flex-row-reverse' : 'lg:flex-row'} items-center gap-12 lg:gap-20 py-24`}
  data-index={index}
>
  <!-- Content -->
  <div class="flex-1 text-center lg:text-left feature-content">
    <div class="inline-flex items-center justify-center w-12 h-12 mb-6 bg-[#f5f5f5] border border-[#e5e5e5] rounded-xl text-[#1a1a1a]">
      <Fragment set:html={icon} />
    </div>
    <h3 class="text-3xl md:text-4xl font-semibold text-[#1a1a1a] mb-4 tracking-tight">
      {title}
    </h3>
    <p class="text-lg text-[#6b6b6b] leading-relaxed max-w-lg">
      {description}
    </p>
  </div>
  
  <!-- Visual/Placeholder -->
  <div class="flex-1 w-full max-w-lg feature-visual-container">
    <div class="relative group">
      <!-- Placeholder container with parallax effect -->
      <div class="feature-visual bg-white rounded-2xl border border-[#e5e5e5] shadow-xl shadow-black/5 overflow-hidden transition-transform duration-500 ease-out">
        <slot />
      </div>
      
      <!-- Decorative elements -->
      <div class="absolute -z-10 inset-0 bg-gradient-to-br from-[#f5f5f5] to-transparent rounded-2xl transform translate-x-4 translate-y-4 group-hover:translate-x-6 group-hover:translate-y-6 transition-transform duration-500"></div>
    </div>
  </div>
</div>

<script>
  // Smooth parallax effect on scroll
  const initParallax = () => {
    const featureItems = document.querySelectorAll('.feature-item');
    
    const handleScroll = () => {
      featureItems.forEach((item) => {
        const visual = item.querySelector('.feature-visual') as HTMLElement;
        const content = item.querySelector('.feature-content') as HTMLElement;
        
        if (!visual || !content) return;
        
        const rect = item.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        
        // Calculate how far the element is from the center of the viewport
        const elementCenter = rect.top + rect.height / 2;
        const viewportCenter = windowHeight / 2;
        const distanceFromCenter = elementCenter - viewportCenter;
        
        // Only apply effect when element is in viewport
        if (rect.top < windowHeight && rect.bottom > 0) {
          // Parallax offset (visual moves slower than scroll)
          const parallaxOffset = distanceFromCenter * 0.08;
          visual.style.transform = `translateY(${parallaxOffset}px)`;
          
          // Content moves slightly in opposite direction for depth
          const contentOffset = distanceFromCenter * -0.03;
          content.style.transform = `translateY(${contentOffset}px)`;
        }
      });
    };
    
    // Use requestAnimationFrame for smooth performance
    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          handleScroll();
          ticking = false;
        });
        ticking = true;
      }
    };
    
    window.addEventListener('scroll', onScroll, { passive: true });
    // Initial call
    handleScroll();
  };
  
  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initParallax);
  } else {
    initParallax();
  }
</script>
